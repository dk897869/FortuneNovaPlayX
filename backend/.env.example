PORT=4000
MONGODB_URI=mongodb://localhost:27017/fortunenv
JWT_SECRET=change_this_in_production

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SERVICE_SID=

# SMTP (optional)
SMTP_HOST=
